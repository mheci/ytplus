   // ... existing helpers ...
 
+  // ===================================================================
+  // OPTIMIZATION: Centralized YT SPA + Player Ready Observer
+  // Replaces 5+ scattered MutationObservers + polling patterns.
+  // Single lightweight observer + event bus emission.
+  // All features should now listen to g.on('player.ready') or g.on('nav.changed')
+  // instead of creating their own observers.
+  // ===================================================================
+  let __ytObserver = null;
+  let __playerReadyFired = false;
+
+  function initCentralYTObserver() {
+    if (__ytObserver) return;
+
+    const root = document.querySelector("ytd-app") || document.documentElement || document.body;
+    if (!root) return;
+
+    __ytObserver = new MutationObserver((mutations) => {
+      // Fast path: check for player
+      const player = document.querySelector("#movie_player");
+      const video = player && player.querySelector("video.html5-main-video");
+
+      if (video && !__playerReadyFired) {
+        __playerReadyFired = true;
+        try { g.emit("player.ready", { player, video }); } catch(e){}
+
+        // Optional: disconnect if we only care about first ready
+        // but we keep it alive for nav changes
+      }
+
+      // Detect major DOM changes that indicate navigation finished
+      // (YouTube fires yt-navigate-finish but we also catch late renders)
+      for (const m of mutations) {
+        if (m.addedNodes && m.addedNodes.length > 0) {
+          // Heuristic: if we see a new ytd-watch-flexy or similar
+          if (document.querySelector("ytd-watch-flexy, ytd-app")) {
+            try { g.emit("nav.changed"); } catch(e){}
+            break;
+          }
+        }
+      }
+    });
+
+    try {
+      __ytObserver.observe(root, {
+        childList: true,
+        subtree: true,
+        attributes: false
+      });
+
+      // Register with memory manager
+      if (typeof _mp !== "undefined" && _mp.safeObserver) {
+        // Already wrapped in some paths; here we just note it.
+      }
+    } catch(e) {}
+
+    // Cleanup on pagehide
+    window.addEventListener("pagehide", () => {
+      try { __ytObserver && __ytObserver.disconnect(); } catch(e){}
+      __ytObserver = null;
+      __playerReadyFired = false;
+    }, { once: true });
+  }
+
   // Existing player detection helpers can now delegate to the central observer.
 
